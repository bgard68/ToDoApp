# Optional: override the API base URL. When empty, the app uses the Vite dev proxy (/api).
# For a production build served separately from the API, set the full origin, e.g.:
# VITE_API_URL=https://localhost:7080
VITE_API_URL=

# Google sign-in: the OAuth 2.0 Web client ID from the Google Cloud console.
# Must match Authentication:Google:ClientId on the backend. Leave empty to hide the button.
VITE_GOOGLE_CLIENT_ID=
